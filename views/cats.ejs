<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/cats.css">
    <title>LatMia – Gatos para adoção</title>
</head>

<body>
    <header class="site-header">
        <span class="header-logo">
            <img src="/assets/images/logo_cat.webp" alt="LatMia">
        </span>

        <div class="header-search">
            <input type="search" placeholder="Buscar gato por raça, nome ou localidade…">
            <button type="button">Buscar</button>
        </div>

        <nav class="header-nav">
            <a class="switch_page" href="/caes">🐶 Cães</a>
            <a href="/meus_anuncios">Meus anúncios</a>
            <a href="/anunciar" class="nav-cta">+ Anunciar</a>
            <a href="/perfil" class="nav-profile">Perfil</a>
        </nav>
    </header>

    <div class="filter-bar">
        <div class="filter-bar-inner">
            <span class="filter-label">Filtrar:</span>
            <button class="filter-chip active">Todos</button>
            <button class="filter-chip">Filhotes</button>
            <button class="filter-chip">Adultos</button>
            <button class="filter-chip">Idosos</button>
            <button class="filter-chip">Pequeno porte</button>
            <button class="filter-chip">Médio porte</button>
            <button class="filter-chip">Grande porte</button>
            <button class="filter-chip">Macho</button>
            <button class="filter-chip">Fêmea</button>
        </div>
    </div>

    <main>

        <section class="animal_carousel">
            <div class="section-header">
                <h2>Recentemente listados</h2>
            </div>
            <div class="carousel_items">

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/sillycat.jpg" alt="Siamês macho">
                            <span class="badge badge-new">Recém listado</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Simba</h3>
                            <p class="card-meta">Siamês · Macho · Filhote</p>
                            <p class="card-location">📍 São Paulo, SP · <span class="card-time">há 1 hora</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/sillycat.jpg" alt="Persa fêmea">
                            <span class="badge badge-urgent">Urgente</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Luna</h3>
                            <p class="card-meta">Persa · Fêmea · Adulta</p>
                            <p class="card-location">📍 Rio de Janeiro, RJ · <span class="card-time">há 3 horas</span>
                            </p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/sillycat.jpg" alt="Maine Coon macho">
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Mufasa</h3>
                            <p class="card-meta">Maine Coon · Macho · Jovem</p>
                            <p class="card-location">📍 Curitiba, PR · <span class="card-time">há 6 horas</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/sillycat.jpg" alt="SRD fêmea">
                            <span class="badge badge-new">Recém listado</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Mel</h3>
                            <p class="card-meta">SRD · Fêmea · Filhote</p>
                            <p class="card-location">📍 Belo Horizonte, MG · <span class="card-time">há 1 dia</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/sillycat.jpg" alt="Ragdoll fêmea">
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Nala</h3>
                            <p class="card-meta">Ragdoll · Fêmea · Adulta</p>
                            <p class="card-location">📍 Porto Alegre, RS · <span class="card-time">há 2 dias</span></p>
                        </div>
                    </a>
                </div>

            </div>
        </section>

        <section class="animal_grid">
            <div class="section-header">
                <h2>Todos os gatos disponíveis <span class="result-count">28 resultados</span></h2>
            </div>
            <div class="grid_items">
                <% if (gatos && gatos.length> 0) { %>
                    <% gatos.forEach(gato=> { %>
                        <div class="container">
                            <a href="/animal/<%= gato.id %>" class="card-link">
                                <div class="card-img-wrap">
                                    <img src="<%= gato.url_foto || '/assets/images/logo_cat.webp' %>"
                                        alt="<%= gato.nome %>">
                                </div>
                                <div class="card-info">
                                    <h3 class="card-name">
                                        <%= gato.nome || 'Sem nome' %>
                                    </h3>
                                    <p class="card-meta">
                                        <%= gato.sexo==='macho' ? 'Macho' : 'Fêmea' %> · Porte <%= gato.porte %>
                                    </p>
                                    <p class="card-location">📍 <%= gato.estado || 'DF' %>
                                    </p>
                                </div>
                            </a>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: #6B7280;">
                                    <span style="font-size: 2rem;">🐾</span>
                                    <p>Nenhum gatinho disponível para adoção no momento.</p>
                                </div>
                                <% } %>
            </div>
        </section>

    </main>
</body>

</html>
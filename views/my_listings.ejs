<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/my_listings.css">
    <title>LatMia – Meus anúncios</title>
</head>

<body>
    <header class="site-header">
        <span class="header-logo">
            <img src="/assets/images/logo_dog_and_cat.webp" alt="LatMia">
        </span>
        <nav class="header-nav">
            <a href="/gatos">🐱 Gatos</a>
            <a href="/caes">🐶 Cães</a>
            <a href="/anunciar" class="nav-cta">+ Anunciar</a>
            <a href="/perfil" class="nav-profile">Perfil</a>
        </nav>
    </header>

    <main>
        <div class="page-header">
            <div>
                <h1>Meus anúncios</h1>
                <p>Gerencie os animais que você colocou para adoção.</p>
            </div>
            <a href="/anunciar" class="btn-primary">+ Novo anúncio</a>
        </div>

        <% let total=0, disponiveis=0, adotados=0, pausados=0; if (animais && animais.length> 0) {
            total = animais.length;
            animais.forEach(a => {
            if (a.status === 'disponivel') disponiveis++;
            if (a.status === 'adotado') adotados++;
            if (a.status === 'pausado') pausados++;
            });
            }
            %>

            <div class="stats-row">
                <div class="stat-card">
                    <span class="stat-number">
                        <%= total %>
                    </span>
                    <span class="stat-label">Total</span>
                </div>
                <div class="stat-card stat-card--green">
                    <span class="stat-number">
                        <%= disponiveis %>
                    </span>
                    <span class="stat-label">Disponíveis</span>
                </div>
                <div class="stat-card stat-card--blue">
                    <span class="stat-number">
                        <%= adotados %>
                    </span>
                    <span class="stat-label">Adotados</span>
                </div>
                <div class="stat-card stat-card--gray">
                    <span class="stat-number">
                        <%= pausados %>
                    </span>
                    <span class="stat-label">Pausados</span>
                </div>
            </div>

            <div class="tab-bar">
                <button class="tab active" data-filter="todos">Todos <span class="tab-count">
                        <%= total %>
                    </span></button>
                <button class="tab" data-filter="disponivel">Disponíveis <span class="tab-count">
                        <%= disponiveis %>
                    </span></button>
                <button class="tab" data-filter="adotado">Adotados <span class="tab-count">
                        <%= adotados %>
                    </span></button>
                <button class="tab" data-filter="pausado">Pausados <span class="tab-count">
                        <%= pausados %>
                    </span></button>
            </div>

            <div class="listings-list">
                <% if (total> 0) { %>
                    <% animais.forEach(animal=> { %>
                        <div class="listing-card" data-status="<%= animal.status %>">
                            <a href="/animal/<%= animal.id %>"
                                class="listing-photo-wrap <%= animal.status === 'pausado' ? 'listing-photo-wrap--paused' : '' %>">
                                <img src="<%= animal.url_foto || (animal.especie === 'cao' ? '/assets/images/logo_dog.webp' : '/assets/images/logo_cat.webp') %>"
                                    alt="<%= animal.nome %>">
                                <% if (animal.status==='adotado' ) { %>
                                    <div class="photo-overlay">Adotado 🎉</div>
                                    <% } %>
                            </a>
                            <div class="listing-info">
                                <div class="listing-main">
                                    <div>
                                        <div class="listing-name-row">
                                            <h3>
                                                <%= animal.nome || 'Sem nome' %>
                                            </h3>
                                            <span class="status-badge status-<%= animal.status %>">
                                                <%= animal.status==='disponivel' ? 'Disponível' :
                                                    (animal.status==='adotado' ? 'Adotado' : 'Pausado' ) %>
                                            </span>
                                        </div>
                                        <p class="listing-meta">
                                            <%= animal.especie==='cao' ? '🐶 Cão' : '🐱 Gato' %> ·
                                                <%= animal.sexo==='macho' ? 'Macho' : 'Fêmea' %> ·
                                                    <%= animal.idade_meses ? animal.idade_meses + ' meses' : 'Idade N/A'
                                                        %> ·
                                                        Porte <%= animal.porte %>
                                        </p>
                                        <p class="listing-date">
                                            <% // Formata a data bonitinha, ex: 12 jun. 2026 const
                                                dataStr=animal.data_anuncio ? new
                                                Date(animal.data_anuncio).toLocaleDateString('pt-BR', {day: 'numeric' ,
                                                month: 'short' , year: 'numeric' }) : '' ; %>
                                                <%= animal.status==='adotado' ? 'Adotado em' : 'Publicado em' %>
                                                    <%= dataStr %>
                                        </p>
                                    </div>
                                    <div class="listing-stats">
                                        <span title="Visualizações">👁 --</span>
                                        <span title="Pedidos de adoção">📋 --</span>
                                    </div>
                                </div>
                                <div class="listing-actions">
                                    <% if (animal.status==='adotado' ) { %>
                                        <a href="/animal/<%= animal.id %>/pedidos" class="action-btn">Ver histórico</a>
                                        <button class="action-btn action-btn--delete"
                                            data-id="<%= animal.id %>">Excluir</button>
                                        <% } else { %>
                                            <a href="/animal/<%= animal.id %>/pedidos"
                                                class="action-btn action-btn--pedidos">Ver pedidos</a>
                                            <a href="/animal/<%= animal.id %>/editar" class="action-btn">Editar</a>

                                            <% if (animal.status==='disponivel' ) { %>
                                                <button class="action-btn action-btn--pause"
                                                    data-id="<%= animal.id %>">Pausar</button>
                                                <% } else if (animal.status==='pausado' ) { %>
                                                    <button class="action-btn action-btn--activate"
                                                        data-id="<%= animal.id %>">Reativar</button>
                                                    <% } %>

                                                        <button class="action-btn action-btn--delete"
                                                            data-id="<%= animal.id %>">Excluir</button>
                                                        <% } %>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } %>
            </div>

            <div class="empty-state" id="empty-state" <%=total===0 ? 'style="display: flex;"' : 'style="display: none;"'
                %>> <span class="empty-icon">🐾</span>
                <p>Nenhum anúncio nessa categoria.</p>
                <a href="/anunciar" class="btn-primary">Criar anúncio</a>
            </div>

    </main>

    <div class="modal-backdrop" id="modal-backdrop">
        <div class="modal">
            <h3>Excluir anúncio?</h3>
            <p>Esta ação é permanente e não poderá ser desfeita.</p>
            <div class="modal-actions">
                <button class="action-btn" id="modal-cancel">Cancelar</button>
                <button class="action-btn action-btn--delete-confirm" id="modal-confirm">Sim, excluir</button>
            </div>
        </div>
    </div>

    <script>
        // ── LÓGICA DAS ABAS (Filtros) ───────────────────
        const tabs = document.querySelectorAll('.tab');
        const cards = document.querySelectorAll('.listing-card');
        const empty = document.getElementById('empty-state');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                const filter = tab.dataset.filter;
                let visible = 0;

                cards.forEach(card => {
                    const show = filter === 'todos' || card.dataset.status === filter;
                    card.style.display = show ? '' : 'none';
                    if (show) visible++;
                });

                empty.style.display = visible === 0 ? 'flex' : 'none';
            });
        });

        // ── MODAL DE EXCLUSÃO (Agora conectado ao Backend) ──
        const backdrop = document.getElementById('modal-backdrop');
        let pendingId = null;

        document.querySelectorAll('.action-btn--delete').forEach(btn => {
            btn.addEventListener('click', () => {
                pendingId = btn.dataset.id;
                backdrop.classList.add('active');
            });
        });

        document.getElementById('modal-cancel').addEventListener('click', () => {
            backdrop.classList.remove('active');
            pendingId = null;
        });

        document.getElementById('modal-confirm').addEventListener('click', async () => {
            if (pendingId) {
                // Trocando o texto do botão para mostrar que está carregando
                const btnConfirm = document.getElementById('modal-confirm');
                btnConfirm.textContent = 'Excluindo...';
                
                try {
                    // Chama a rota DELETE no Node.js
                    const resposta = await fetch(`/api/animais/${pendingId}`, { method: 'DELETE' });
                    const resultado = await resposta.json();

                    if (resultado.success) {
                        const card = document.querySelector(`.action-btn--delete[data-id="${pendingId}"]`).closest('.listing-card');
                        if (card) {
                            card.style.animation = 'fadeOut 0.3s ease forwards';
                            setTimeout(() => {
                                card.remove();
                                window.location.reload(); // Recarrega para atualizar os números do topo
                            }, 300);
                        }
                    } else {
                        alert('Erro ao excluir: ' + resultado.erro);
                    }
                } catch (error) {
                    alert('Erro de conexão ao tentar excluir o anúncio.');
                }
                btnConfirm.textContent = 'Sim, excluir';
            }
            backdrop.classList.remove('active');
            pendingId = null;
        });

        // ── BOTÃO PAUSAR (Conectado ao Backend) ────────
        document.querySelectorAll('.action-btn--pause').forEach(btn => {
            btn.addEventListener('click', async () => {
                const animalId = btn.dataset.id;
                btn.textContent = 'Pausando...'; // Feedback visual

                try {
                    const resposta = await fetch(`/api/animais/${animalId}/status`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status: 'pausado' })
                    });
                    const resultado = await resposta.json();

                    if (resultado.success) {
                        window.location.reload(); // Atualiza a tela para mudar de aba e contadores
                    } else {
                        alert('Erro ao pausar: ' + resultado.erro);
                        btn.textContent = 'Pausar';
                    }
                } catch (error) {
                    alert('Erro de conexão.');
                    btn.textContent = 'Pausar';
                }
            });
        });

        // ── BOTÃO REATIVAR (Conectado ao Backend) ──────
        document.querySelectorAll('.action-btn--activate').forEach(btn => {
            btn.addEventListener('click', async () => {
                const animalId = btn.dataset.id;
                btn.textContent = 'Reativando...'; // Feedback visual

                try {
                    const resposta = await fetch(`/api/animais/${animalId}/status`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status: 'disponivel' })
                    });
                    const resultado = await resposta.json();

                    if (resultado.success) {
                        window.location.reload(); // Atualiza a tela para mudar de aba e contadores
                    } else {
                        alert('Erro ao reativar: ' + resultado.erro);
                        btn.textContent = 'Reativar';
                    }
                } catch (error) {
                    alert('Erro de conexão.');
                    btn.textContent = 'Reativar';
                }
            });
        });
    </script>
</body>

</html>
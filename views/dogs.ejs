                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Poodle fêmea">
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Nina</h3>
                            <p class="card-meta">Poodle · Fêmea · Adulta</p>
                            <p class="card-location">📍 Belo Horizonte, MG · <span class="card-time">há 1 dia</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Border Collie macho">
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Bolt</h3>
                            <p class="card-meta">Border Collie · Macho · Jovem</p>
                            <p class="card-location">📍 Curitiba, PR · <span class="card-time">há 1 dia</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Beagle macho">
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Pipoca</h3>
                            <p class="card-meta">Beagle · Macho · Filhote</p>
                            <p class="card-location">📍 Porto Alegre, RS · <span class="card-time">há 2 dias</span></p>

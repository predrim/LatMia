<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/dogs.css">
    <title>LatMia – Cães de adoção</title>
</head>

<body>
    <header class="site-header">
        <span class="header-logo">
            <img src="/assets/images/logo_dog.webp" alt="LatMia">
        </span>

        <div class="header-search">
            <input type="search" placeholder="Buscar cão por raça, nome ou localidade…">
            <button type="button">Buscar</button>
        </div>

        <nav class="header-nav">
            <a class="switch_page" href="/gatos">🐱 Gatos</a>
            <a href="/meus_anuncios">Meus anúncios</a>
            <a href="/anunciar" class="nav-cta">+ Anunciar</a>
            <a href="/perfil" class="nav-profile">Perfil</a>
        </nav>
    </header>

    <div class="filter-bar">
        <div class="filter-bar-inner">
            <span class="filter-label">Filtrar:</span>
            <button class="filter-chip active">Todos</button>
            <button class="filter-chip">Filhotes</button>
            <button class="filter-chip">Adultos</button>
            <button class="filter-chip">Idosos</button>
            <button class="filter-chip">Pequeno porte</button>
            <button class="filter-chip">Médio porte</button>
            <button class="filter-chip">Grande porte</button>
            <button class="filter-chip">Macho</button>
            <button class="filter-chip">Fêmea</button>
        </div>
    </div>

    <main>

        <section class="animal_carousel">
            <div class="section-header">
                <h2>Recentemente listados</h2>
            </div>
            <div class="carousel_items">

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Shih Tzu fêmea">
                            <span class="badge badge-new">Recém listado</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Mel</h3>
                            <p class="card-meta">Shih Tzu · Fêmea · Filhote</p>
                            <p class="card-location">📍 São Paulo, SP · <span class="card-time">há 2 horas</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Labrador macho">
                            <span class="badge badge-urgent">Urgente</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Thor</h3>
                            <p class="card-meta">Labrador · Macho · Adulto</p>
                            <p class="card-location">📍 Rio de Janeiro, RJ · <span class="card-time">há 5 horas</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Poodle fêmea">
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Nina</h3>
                            <p class="card-meta">Poodle · Fêmea · Adulta</p>
                            <p class="card-location">📍 Belo Horizonte, MG · <span class="card-time">há 1 dia</span></p>
                        </div>
                    </a>
                </div>

                <div class="container">
                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Border Collie macho">
                            <span class="badge badge-new">Recém listado</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Bolt</h3>
                            <p class="card-meta">Border Collie · Macho · Jovem</p>
                            <p class="card-location">📍 Curitiba, PR · <span class="card-time">há 1 dia</span></p>

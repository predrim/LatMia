                    <a href="" class="card-link">
                        <div class="card-img-wrap">
                            <img src="/assets/images/racas-de-cachorro-shihtzu-04.jpg" alt="Golden macho">
                            <span class="badge badge-urgent">Urgente</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">Bob</h3>
                            <p class="card-meta">Golden Retriever · Macho · Adulto</p>
                            <p class="card-location">📍 Brasília, DF · <span class="card-time">há 3 dias</span></p>
